public static int findDivisor(int []arr){
  int n = arr.length;
  int minValue = Integer.MAX_VALUE;
  
  // find the Absolute Minimum  O(n)
  for (int i = 0 ; i < n ;i++){

    if(Math.abs(arr[i]) < minValue && Math.abs(arr[i]) != 1){
      minValue = Math.abs(arr[i]);
    }

  }

  //return -1 of there is  arr[i] % minValue != 0 
  for(int i = 0 ; i < n ; i++){
    if(Math.abs(arr[i]) % minValue != 0){
      return -1;
    }
  }

  return minValue;
}
