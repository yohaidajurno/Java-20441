public static int maxFactor(int num){
   // we send the square because the requiremnet hinted 
    return maxFactor(num,(int)Math.sqrt(num));
}
private static int maxFactor(int num,int factor){
    // stop case
    if(factor < 2){
        return -1;
    }
    //check case
    if(isFactor(num,factor,0,1,"")){
        return factor;
    }
    //take case
    return maxFactor(num,factor-1);
}
private static boolean isFactor(int num,int factor,int pow,int currPow,String factorial){    
    // stop case
     if(currPow > num){
        return false;
    }
    //check final case 
    if(num == currPow){
        System.out.println(factorial + currPow);
        return true;    
    }
    //calc for 2 options case
    int nextPow = pow + 1;
    int nextCurrPow = (int)Math.pow(factor,nextPow);
    //two options case 
    boolean op1 = isFactor(num - currPow,factor,nextPow,nextCurrPow,factorial+currPow+"\t");
    boolean op2 = isFactor(num,factor,nextPow,nextCurrPow,factorial);

    return op1 || op2;
}