public static int where(int[] vec) {
    return where(vec, 0, vec.length - 1);
}

private static int where(int[] vec, int left, int right) {
    if (left >= right)
        return -1;

    if (sum(vec, 0, left) == sum(vec, left + 1, right))
        return left + 1;

    return where(vec, left + 1, right);
}
    public static boolean isBalanced(int[] vec, int k) {

        return isBalanced(vec, 0, vec.length - 1, k);

    }

    private static boolean isBalanced(int[] vec, int left, int right, int k) {

        if (k == 0)
            return true;

        int p = where(vec, left, right);

        if (p == -1)
            return false;

        return isBalanced(vec, left, p - 1, k - 1) &&
               isBalanced(vec, p, right, k - 1);

    }

    private static int sum(int[] v, int lo, int hi) {

        if (lo > hi)
            return 0;

        return v[lo] + sum(v, lo + 1, hi);

    }