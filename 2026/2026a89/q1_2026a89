public static boolean digitsSumArray(int[] arr, int num) {
    return digitsSumArray(arr, num, 0, "", 0);
}

private static boolean digitsSumArray(int[] arr, int num, int i, String path, int current) {

    if (i == arr.length) {
        if (num - current == 0) {
            if (path.equals(""))
                System.out.println(current);
            else
                System.out.println(path + "\t" + current);

            return true;
        }
        return false;
    }

    current = current * 10 + arr[i];

    String newPath;

    if (path.equals(""))
        newPath = "" + current;
    else
        newPath = path + "\t" + current;

    boolean op1 = digitsSumArray(arr, num - current, i + 1, newPath, 0);

    boolean op2 = digitsSumArray(arr, num, i + 1, path, current);

    return op1 || op2;
}