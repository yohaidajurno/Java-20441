public static boolean digitsSumArray(int[] arr, int num) {
    // Start with the first digit as the current number.
    return digitsSumArray(arr, num, 1, arr[0], "");
}

private static boolean digitsSumArray(int[] arr, int num, int index, int current, String path) {
    // Base case: all digits have been processed.
    if (index == arr.length) {
        // Check whether the final number equals the remaining target.
        if (num == current) {
            // Print the successful division into numbers.
            System.out.println(path + current);
            return true;
        }

        return false;
    }

    // Option 1: Attach the next digit to the current number.
    // Option 2: Finish the current number and start a new one.
    return digitsSumArray(arr, num, index + 1, current * 10 + arr[index], path)
            || digitsSumArray(arr, num - current, index + 1, arr[index], path + current + " ");
}