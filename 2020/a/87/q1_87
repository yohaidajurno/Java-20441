public static int totalWays(int[][] mat, int k) {
    // Start at the top-left cell.
    // 'a' and 'b' are dummy directions so the first move
    // will not be counted as a direction change.
    return totalWays(mat, k, 0, 0, 'a', 'b');
}

private static int totalWays(int[][] mat, int k, int i, int j, char before, char current) {
                     
    // The current position is outside the matrix
    if (i > mat.length - 1 || j > mat[0].length - 1) {
        return 0;
    }

    // A change from right to down or from down to right occurred
    if ((before == 'R' && current == 'D') ||
        (before == 'D' && current == 'R')) {
        k--;
    }

    // The bottom-right cell was reached
    if (i == mat.length - 1 && j == mat[0].length - 1) {
        // Count this path only if it has exactly the required
        // number of direction changes
        if (k == 0) {
            return 1;
        }

        return 0;
    }

    // Continue one cell downward
    int down = totalWays(
        mat, k, i + 1, j, current, 'D'
    );

    // Continue one cell to the right
    int right = totalWays(
        mat, k, i, j + 1, current, 'R'
    );

    // Return the number of valid paths from both possibilities
    return down + right;
}