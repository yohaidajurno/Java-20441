public static void printTriplets(int[] a, int num) {
    // The algorithm assumes that the array is sorted
    for (int i = 0; i < a.length - 2; i++) {
        // Search for two additional values after a[i]
        int j = i + 1;
        int k = a.length - 1;

        // Move the two pointers toward each other
        while (j < k) {
            // Calculate the product of the current triplet
            int triple = a[i] * a[j] * a[k];

            if (triple == num) {
                // A matching triplet was found
                System.out.println(
                    a[i] + "\t" + a[j] + "\t" + a[k]
                );

                // Continue searching for additional triplets
                j++;
                k--;
            } else if (triple < num) {
                // Increase the product by moving the left pointer
                j++;
            } else {
                // Decrease the product by moving the right pointer
                k--;
            }
        }
    }
}