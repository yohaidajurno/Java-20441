public static int findMaximum(int [][]mat){
    if(mat.length == 0 || mat[0][0] == -1){
        return -1;
    }
    return findMaximum(mat,0,0);
}
private static int findMaximum(int[][]mat,int i,int j){

if( i< 0 || j<0 || i >mat.length -1|| j> mat[0].length -1||mat[i][j] == -1){
    return 0;
}

if(i % 2 == 0){
    return mat[i][j] + Math.max(findMaximum(mat,i+1,j),findMaximum(mat,i,j+1));
}else
   return mat[i][j] + Math.max(findMaximum(mat,i+1,j),findMaximum(mat,i,j-1));

}