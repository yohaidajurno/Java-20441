public static int howManyDivisors(int[] arr, int num) {

    // Size of each window: num elements left + center + num elements right
    int windowSize = 2 * num + 1; 

    // If the array is too small for even one full window
    if (arr.length < windowSize) {
        return -1;
    }

    int currentSum = 0;
    int count = 0;

    // Calculate the sum of the first window
    for (int i = 0; i < windowSize; i++) {
        currentSum += arr[i];
    }

    // Check the first window.
    // Its center is at index num.
    if (currentSum % arr[num] == 0) {
        count++;
    }

    // Slide the window one step at a time
    for (int i = windowSize; i < arr.length; i++) {

        // Remove the element that leaves the window
        currentSum -= arr[i - windowSize];

        // Add the new element entering the window
        currentSum += arr[i];

        // The center of the current window is num places before i
        if (currentSum % arr[i - num] == 0) {
            count++;
        }
    }

    return count;
}