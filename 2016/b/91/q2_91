public static boolean findAverage(int [] arr,double x){
  double sum = 0,average = 0;
  int low = 0 ,high = arr.length-1;

  for(int i = 0 ; i < arr.length ;i++){
    sum += arr[i];
  }

  while(low <= high){
    average = sum / (high - low + 1);
    if(average == x){

    System.out.println(low+"---"+high);
    return true;
    }
    if ( average >  x){
      sum -= arr[high];
      high--;
    }else{
      sum -= arr[low];
      low++;
    }
}
 return false;
}
