public static boolean findX(int a[],int x){
  if(a.length < 2){
    return false;
  }
  int low = 0,high = a.length -1;
  
  while(low < high){
     int mid = low + (high - low) / 2;
     int sum = a[mid]+ a[mid+1];

    if(sum == x )  
      return true;
   
    if (sum < x)  
      low = mid + 1;

    else 
       high = mid ;
  }
  return false;

}