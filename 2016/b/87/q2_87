public static int subStrC(String s, char c) {
    int count = 0;

    for (int i = 0; i < s.length(); i++)
        if (s.charAt(i) == c)
            count++;

    return Math.max(0, count - 2);
}
public static int subStrMaxC(String s, char c, int k) {
    int countC = 0, totalCount = 0;

    for (int i = 0; i < s.length(); i++) {
        if (s.charAt(i) == c) {
            totalCount += Math.min(k + 1, countC);
            countC++;
        }
    }

    return totalCount;
}