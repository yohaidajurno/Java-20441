public static int countTriplets(int[] arr, int num) {
    int count = 0;          // Counts valid triplets
    int n = arr.length;     // Length of array
    int j, k;

    // Choose the first number of the triplet
    for (int i = 0; i < n - 2; i++) {

        j = i + 1;          // Second number starts after i
        k = n - 1;          // Third number starts at the end

        while (j < k) {

            // If the sum is too big or equal to num
            if (arr[i] + arr[j] + arr[k] >= num) {
                k--;        // Move left to make the sum smaller

            } else {
                // Sum is smaller than num.
                // Since the array is sorted, all values from j+1 to k
                // also create valid triplets with arr[i] and arr[j].
                count += (k - j);

                // Move j right and check the next possibility
                j++;
            }
        }
    }

    return count;           // Return total number of valid triplets
}