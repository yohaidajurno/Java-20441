public static boolean covers(int[][] mat, int[] arr, int k) {
    // Start checking from row 0
    return covers(mat, arr, k, 0);
}

private static boolean covers(int[][] mat, int[] arr, int k, int startRow) {

    // We used more than k rows
    if (k < 0) {
        return false;
    }

    // No more rows left to check
    if (startRow == mat.length) {
        // Success only if every element in arr became 0
        return allZero(arr);
    }

    // Create a copy of arr because one recursive option
    // will modify it
    int[] temp = new int[arr.length];
    copy(temp, arr);

    // Use the current row to "cover" elements in temp
    // Matching elements are usually changed to 0
    xZero(temp, mat[startRow]);

    // Two choices:
    // 1. Take the current row:
    //    use temp, decrease k, move to next row
    //
    // 2. Skip the current row:
    //    keep original arr, keep k unchanged, move to next row
    return covers(mat, temp, k - 1, startRow + 1)
            || covers(mat, arr, k, startRow + 1);
}