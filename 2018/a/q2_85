///    השיטה מחזירה את מס׳ רצף איברים הסמוכים הארוך ביותר שסכומם אי זוגי אם איו תחזיר אפס
/// סיבוכיות זמן O(n^3)
public static int what (int [] a){
int max = 0;

    for(int i = 0; i < a.length;i++){
    int sum = 0; 
  
    for(int j =  i ; j< a.length;j++){
    sum +=a[j];

      if(sum %% 2 == 1){
      max = Math.max(max,j-i+1);
      } 
    }
  }
}
return max;


